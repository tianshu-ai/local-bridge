{
  "name": "@tianshu-ai/local-bridge",
  "version": "0.7.3",
  "description": "Local bridge for tianshu — dial into a tianshu server over WebSocket and expose your machine's tools (browser, files, shell) to the agent via reverse-MCP.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tianshu-ai/local-bridge.git"
  },
  "homepage": "https://github.com/tianshu-ai/local-bridge#readme",
  "bugs": {
    "url": "https://github.com/tianshu-ai/local-bridge/issues"
  },
  "type": "module",
  "bin": {
    "tsbridge": "dist/index.js",
    "tianshu-local-bridge": "dist/index.js"
  },
  "files": [
    "dist",
    "app/TianshuBridge.swift",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.19.0",
    "playwright": "^1.56.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/ws": "^8.5.12",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
